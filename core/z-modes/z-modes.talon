hello out there: "Shalom world90213!!"

move <user.dpad_input>: user.dpad_move(user.dpad_input)
move again: user.dpad_repeat_move()
attack <user.dpad_input>: user.dpad_attack(user.dpad_input)

add <user.text>$: user.rz_add(user.text)
zed one: user.rz_set_format("PUBLIC_CAMEL_CASE")
zed one l: user.rz_set_format("PRIVATE_CAMEL_CASE", "PUBLIC_CAMEL_CASE")
zed ten: user.rz_set_format("DOUBLE_COLON_SEPARATED")
